# Server Port (Render uses 10000 by default)
PORT=10000

# MongoDB Atlas connection string
# Get this from: MongoDB Atlas → Your Cluster → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/WaveMusic?retryWrites=true&w=majority

# JWT Secret - use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Client origin(s) - comma-separated for multiple origins
# Replace with your actual Vercel deployment URL
CLIENT_ORIGIN=https://wave-music-client.vercel.app

# Environment
NODE_ENV=production
